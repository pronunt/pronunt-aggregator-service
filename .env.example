APP_NAME=pronunt-aggregator-service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_USE_COLORS=true
REQUEST_ID_HEADER=X-Request-ID
HTTP_TIMEOUT_SECONDS=10
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=pronunt
MONGODB_PR_COLLECTION=aggregator_pull_requests
AGGREGATOR_STALE_AFTER_HOURS=72
CONFIG_SERVICE_URL=http://pronunt-config-service:8000
AUTH_ENABLED=false
ALLOW_UNSAFE_DEV_AUTH=true
KEYCLOAK_ISSUER=http://keycloak.pronunt.com/realms/pronunt
KEYCLOAK_AUDIENCE=pronunt-api
KEYCLOAK_JWKS_URL=http://keycloak.pronunt.com/realms/pronunt/protocol/openid-connect/certs
CONFIG_SERVICE_URL=http://pronunt-config-service:8000
AI_SERVICE_URL=http://pronunt-ai-service:8000
