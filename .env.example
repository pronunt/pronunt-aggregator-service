# Core runtime
APP_NAME=pronunt-aggregator-service
APP_ENV=<set-app-environment>
APP_HOST=<set-bind-host>
APP_PORT=<set-bind-port>
LOG_LEVEL=<set-log-level>
LOG_USE_COLORS=<true-or-false>
REQUEST_ID_HEADER=<set-request-id-header>
HTTP_TIMEOUT_SECONDS=<set-http-timeout-seconds>

# Data storage
MONGODB_URI=<set-mongodb-uri>
MONGODB_DATABASE=<set-mongodb-database>
MONGODB_PR_COLLECTION=<set-pr-collection-name>

# Scoring/runtime behavior
AGGREGATOR_STALE_AFTER_HOURS=<set-stale-threshold-hours>
CONFIG_SERVICE_URL=<set-config-service-url>
AI_SERVICE_URL=<set-ai-service-url>

# Auth
AUTH_ENABLED=<true-or-false>
ALLOW_UNSAFE_DEV_AUTH=<true-or-false>
KEYCLOAK_ISSUER=<set-keycloak-issuer>
KEYCLOAK_AUDIENCE=<set-keycloak-audience>
KEYCLOAK_JWKS_URL=<set-keycloak-jwks-url>
